# ======================================================================
# Monitoring stack — env template
# Copy to the Coolify env var UI (NOT a literal .env file on the server)
# ======================================================================

# --- InfluxDB 2.x bootstrap ------------------------------------------------
# These are read ONCE on first boot to create the admin user, org, bucket
# and token. After that they're ignored (the data lives in the persistent
# volume at /data/monitoring/influxdb).
INFLUX_ADMIN_USERNAME=admin
INFLUX_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
INFLUX_ORG=fournico
INFLUX_BUCKET=server_health
INFLUX_RETENTION=60d

# Generate a long random token ONCE with:
#   openssl rand -hex 32
# Used by both InfluxDB (as admin token) AND Telegraf (to write metrics).
INFLUX_TOKEN=CHANGE_ME_64_HEX_CHARS

# --- Grafana ---------------------------------------------------------------
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
GF_SERVER_DOMAIN=metrics.fournico.com
GF_SERVER_ROOT_URL=https://metrics.fournico.com

# --- ntfy (self-hosted, bundled in this stack) -----------------------------
# The ntfy service runs alongside Grafana in this stack. You'll expose it
# publicly at NTFY_BASE_URL via Coolify, subscribe to a topic on your
# Android phone, and Grafana will POST alerts to NTFY_WEBHOOK_URL.

# Public URL where ntfy is reachable. Must match the Coolify domain.
NTFY_BASE_URL=https://ntfy.fournico.com

# Default access policy for the ntfy server:
#   read-write  → anyone with a URL can publish + subscribe (default)
#   deny-all    → require auth (see README for user setup)
NTFY_AUTH_DEFAULT_ACCESS=read-write

# The topic URL Grafana POSTs alerts to. Pick an unguessable topic name
# so strangers can't subscribe and read your alerts. Must begin with the
# NTFY_BASE_URL above.
NTFY_WEBHOOK_URL=https://ntfy.fournico.com/ax42-alerts-CHANGE-ME

# --- Docker group ID on the host ------------------------------------------
# Run `getent group docker | cut -d: -f3` on the AX42 to get this value.
# Telegraf needs it to read /var/run/docker.sock.
DOCKER_GID=999
